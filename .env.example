# =====================================================
# VoiceVault Environment Configuration
# =====================================================
# Copy this file to .env and fill in your values

# Wallet Address
SUI_ADDRESS=0x...
SUI_ALIAS=your-wallet-alias

# Network
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io
SUI_FULL_NODE_URL=https://fullnode.testnet.sui.io:443

# Gas Budget
SUI_GAS_BUDGET=10000000

# Smart Contracts (from Published.toml)
SUI_PACKAGE_ID=0x1ad12f0fd581dbd4fef7a30c9cff9bececfca1da450fe53257791502b3db073d
SUI_UPGRADE_CAPABILITY=0x11104c8cc167bad70c519ca855c10ec71d8f97114d33e38888d388c4d39b6f30

# VoiceRegistry Object ID (created by init_registry)
SUI_VOICE_REGISTRY_ID=0x1ad12f0fd581dbd4fef7a30c9cff9bececfca1da450fe53257791502b3db073d

# =====================================================
# FRONTEND CONFIGURATION (Vite)
# =====================================================

# API Server
VITE_API_URL=http://localhost:8000
VITE_PROXY_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# For production (Vercel):
# VITE_API_URL=https://voicevault.onrender.com
# VITE_PROXY_URL=https://voicevault.onrender.com
# VITE_BACKEND_URL=https://voicevault.onrender.com

# Walrus Configuration
VITE_WALRUS_AGGREGATOR_URL=http://localhost:8000/api/walrus

# Sui Configuration (exposed to frontend)
VITE_SUI_NETWORK=testnet
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io
VITE_SUI_PACKAGE_ID=0x1ad12f0fd581dbd4fef7a30c9cff9bececfca1da450fe53257791502b3db073d
VITE_SUI_VOICE_REGISTRY_ID=0x1ad12f0fd581dbd4fef7a30c9cff9bececfca1da450fe53257791502b3db073d

# =====================================================
# BACKEND CONFIGURATION
# =====================================================

# Server Port
PORT=8000
BACKEND_URL=http://localhost:8000

# For production (Render):
# PORT=8080
# BACKEND_URL=https://voicevault-backend.onrender.com

# Walrus Storage
WALRUS_STORAGE_MODE=local
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=http://localhost:8000/api/walrus
WALRUS_EPOCHS=5
WALRUS_DELETABLE=true
WALRUS_MAX_BLOB_SIZE=10485760

# For production, use:
# WALRUS_STORAGE_MODE=remote
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# API Security
API_SECRET_KEY=your_secret_key_here
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# For production:
# CORS_ORIGINS=["https://voicevault.vercel.app", "https://yourdomain.com"]

# Logging
LOG_LEVEL=info

# =====================================================
# LIVEKIT — required for live voice agent rooms
# Get credentials at https://cloud.livekit.io
# See docs/LIVEKIT_SETUP.md for full setup guide
# =====================================================

LIVEKIT_URL=wss://your-project-abc123.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret

# =====================================================
# LLM PROVIDERS — used by the LiveKit agent worker
# Add whichever provider you want to use
# =====================================================

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=
# GROQ_API_KEY=

# =====================================================
# x402 PAY-PER-USE
# Default price callers pay for 2 TTS generations
# 100_000_000 MIST = 0.1 SUI
# =====================================================

X402_DEFAULT_PRICE_MIST=100000000
X402_DEFAULT_USES=2

# =====================================================
