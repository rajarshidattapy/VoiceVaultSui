# Frontend-only environment variables
# These are exposed to the browser (VITE_ prefix)

# API Endpoint
VITE_API_URL=http://localhost:8000

# For production on Vercel, set to your backend URL:
# VITE_API_URL=https://voicevault-backend.onrender.com

VITE_PROXY_URL=http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# Murf TTS is called through the backend.
# Put MURF_API_KEY in backend/.env, not frontend/.env.

# Walrus Configuration
VITE_WALRUS_AGGREGATOR_URL=http://localhost:8000/api/walrus

# Sui Configuration (public values only - safe for browser)
VITE_SUI_NETWORK=testnet
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io
VITE_SUI_PACKAGE_ID=0x1ad12f0fd581dbd4fef7a30c9cff9bececfca1da450fe53257791502b3db073d
VITE_SUI_VOICE_REGISTRY_ID=0x1ad12f0fd581dbd4fef7a30c9cff9bececfca1da450fe53257791502b3db073d

# Note: This file should be used locally only.
# In production (Vercel), set environment variables in:
# Vercel Dashboard → Settings → Environment Variables

