{
  "family": "voicevault-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT_ID:role/voicevault-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::REPLACE_ACCOUNT_ID:role/voicevault-ecs-task-role",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "volumes": [
    {
      "name": "voicevault-storage",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-REPLACE_EFS_FILE_SYSTEM_ID",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-REPLACE_EFS_ACCESS_POINT_ID",
          "iam": "ENABLED"
        }
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "voicevault-api",
      "image": "REPLACE_ACCOUNT_ID.dkr.ecr.REPLACE_REGION.amazonaws.com/voicevault-backend:latest",
      "essential": true,
      "command": ["python", "-m", "uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"],
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "voicevault-storage",
          "containerPath": "/var/lib/voicevault",
          "readOnly": false
        }
      ],
      "environment": [
        {"name": "PORT", "value": "8000"},
        {"name": "PYTHONUNBUFFERED", "value": "1"},
        {"name": "PYTHONDONTWRITEBYTECODE", "value": "1"},
        {"name": "BACKEND_URL", "value": "https://REPLACE_WITH_BACKEND_HOST"},
        {"name": "VOICEVAULT_STORAGE_DIR", "value": "/var/lib/voicevault"},
        {"name": "VOICEVAULT_TTS_MODEL_PATH", "value": "/var/lib/voicevault/models/lux-tts"},
        {"name": "VOICEVAULT_TTS_ASR_MODEL_PATH", "value": "/var/lib/voicevault/models/whisper"},
        {"name": "VOICEVAULT_TTS_DEVICE", "value": "cpu"},
        {"name": "VOICEVAULT_TTS_THREADS", "value": "4"},
        {"name": "CORS_ORIGINS", "value": "[\"https://REPLACE_WITH_FRONTEND_HOST\",\"http://localhost:5173\"]"},
        {"name": "CORS_ALLOW_CREDENTIALS", "value": "true"},
        {"name": "SUI_NETWORK", "value": "testnet"},
        {"name": "SUI_RPC_URL", "value": "https://fullnode.testnet.sui.io"},
        {"name": "SUI_FULL_NODE_URL", "value": "https://fullnode.testnet.sui.io:443"},
        {"name": "SUI_PACKAGE_ID", "value": "0x1ad12f0fd581dbd4fef7a30c9cff9bececfca1da450fe53257791502b3db073d"},
        {"name": "SUI_VOICE_REGISTRY_ID", "value": "0xfad2808bcd104197b53b1fddede5f25d5c16303b147d280c2aa7ff69d27e5d59"},
        {"name": "WALRUS_STORAGE_MODE", "value": "remote"},
        {"name": "WALRUS_PUBLISHER_URL", "value": "https://publisher.walrus-testnet.walrus.space"},
        {"name": "WALRUS_AGGREGATOR_URL", "value": "https://aggregator.walrus-testnet.walrus.space"},
        {"name": "WALRUS_EPOCHS", "value": "5"},
        {"name": "WALRUS_DELETABLE", "value": "true"},
        {"name": "WALRUS_MAX_BLOB_SIZE", "value": "10485760"},
        {"name": "LIVEKIT_AGENT_NAME", "value": "swaraos-voice-agent"},
        {"name": "LIVEKIT_AGENT_EXTERNAL", "value": "true"},
        {"name": "LIVEKIT_AGENT_MANAGED", "value": "false"},
        {"name": "AGENT_NETWORK_MCP_ENABLED", "value": "true"},
        {"name": "AGENT_NETWORK_MCP_URL", "value": "http://127.0.0.1:8001/sse"},
        {"name": "AGENT_NETWORK_MCP_REQUIRED", "value": "false"},
        {"name": "MCP_HOST", "value": "127.0.0.1"},
        {"name": "MCP_PORT", "value": "8001"},
        {"name": "MAX_DELEGATION_DEPTH", "value": "2"},
        {"name": "AGENT_DELEGATION_MODEL", "value": "gpt-4o-mini"},
        {"name": "OPENAI_REALTIME_MODEL", "value": "gpt-realtime"},
        {"name": "X402_DEFAULT_PRICE_MIST", "value": "100000000"},
        {"name": "X402_DEFAULT_USES", "value": "2"}
      ],
      "secrets": [
        {"name": "OPENAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:OPENAI_API_KEY::"},
        {"name": "LIVEKIT_URL", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:LIVEKIT_URL::"},
        {"name": "LIVEKIT_API_KEY", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:LIVEKIT_API_KEY::"},
        {"name": "LIVEKIT_API_SECRET", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:LIVEKIT_API_SECRET::"},
        {"name": "API_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:API_SECRET_KEY::"}
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/healthz || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/voicevault",
          "awslogs-region": "REPLACE_REGION",
          "awslogs-stream-prefix": "api"
        }
      }
    },
    {
      "name": "voicevault-mcp",
      "image": "REPLACE_ACCOUNT_ID.dkr.ecr.REPLACE_REGION.amazonaws.com/voicevault-backend:latest",
      "essential": true,
      "command": ["python", "swaraos_mcp_server.py"],
      "dependsOn": [
        {
          "containerName": "voicevault-api",
          "condition": "HEALTHY"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "voicevault-storage",
          "containerPath": "/var/lib/voicevault",
          "readOnly": false
        }
      ],
      "environment": [
        {"name": "PYTHONUNBUFFERED", "value": "1"},
        {"name": "PYTHONDONTWRITEBYTECODE", "value": "1"},
        {"name": "BACKEND_URL", "value": "http://127.0.0.1:8000"},
        {"name": "VOICEVAULT_STORAGE_DIR", "value": "/var/lib/voicevault"},
        {"name": "MCP_HOST", "value": "127.0.0.1"},
        {"name": "MCP_PORT", "value": "8001"},
        {"name": "MAX_DELEGATION_DEPTH", "value": "2"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/voicevault",
          "awslogs-region": "REPLACE_REGION",
          "awslogs-stream-prefix": "mcp"
        }
      }
    },
    {
      "name": "voicevault-agent-worker",
      "image": "REPLACE_ACCOUNT_ID.dkr.ecr.REPLACE_REGION.amazonaws.com/voicevault-backend:latest",
      "essential": true,
      "command": ["python", "agent_worker.py", "start"],
      "dependsOn": [
        {
          "containerName": "voicevault-api",
          "condition": "HEALTHY"
        },
        {
          "containerName": "voicevault-mcp",
          "condition": "START"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "voicevault-storage",
          "containerPath": "/var/lib/voicevault",
          "readOnly": false
        }
      ],
      "environment": [
        {"name": "PYTHONUNBUFFERED", "value": "1"},
        {"name": "PYTHONDONTWRITEBYTECODE", "value": "1"},
        {"name": "BACKEND_URL", "value": "http://127.0.0.1:8000"},
        {"name": "VOICEVAULT_STORAGE_DIR", "value": "/var/lib/voicevault"},
        {"name": "VOICEVAULT_TTS_MODEL_PATH", "value": "/var/lib/voicevault/models/lux-tts"},
        {"name": "VOICEVAULT_TTS_ASR_MODEL_PATH", "value": "/var/lib/voicevault/models/whisper"},
        {"name": "VOICEVAULT_TTS_DEVICE", "value": "cpu"},
        {"name": "VOICEVAULT_TTS_THREADS", "value": "4"},
        {"name": "WALRUS_STORAGE_MODE", "value": "remote"},
        {"name": "WALRUS_AGGREGATOR_URL", "value": "https://aggregator.walrus-testnet.walrus.space"},
        {"name": "LIVEKIT_AGENT_NAME", "value": "swaraos-voice-agent"},
        {"name": "LIVEKIT_AGENT_MODE", "value": "start"},
        {"name": "LIVEKIT_AGENT_HTTP_PORT", "value": "0"},
        {"name": "AGENT_NETWORK_MCP_ENABLED", "value": "true"},
        {"name": "AGENT_NETWORK_MCP_URL", "value": "http://127.0.0.1:8001/sse"},
        {"name": "OPENAI_REALTIME_MODEL", "value": "gpt-realtime"},
        {"name": "MAX_DELEGATION_DEPTH", "value": "2"}
      ],
      "secrets": [
        {"name": "OPENAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:OPENAI_API_KEY::"},
        {"name": "LIVEKIT_URL", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:LIVEKIT_URL::"},
        {"name": "LIVEKIT_API_KEY", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:LIVEKIT_API_KEY::"},
        {"name": "LIVEKIT_API_SECRET", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT_ID:secret:voicevault/prod-REPLACE_SECRET_SUFFIX:LIVEKIT_API_SECRET::"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/voicevault",
          "awslogs-region": "REPLACE_REGION",
          "awslogs-stream-prefix": "worker"
        }
      }
    }
  ]
}
