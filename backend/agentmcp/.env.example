# =====================================================
# SwaraOS — Monad Testnet Configuration
# Copy this file to .env and fill in your values
# =====================================================

# External API Keys
SARVAM_API_KEY=your_sarvam_api_key

# =====================================================
# MONAD BLOCKCHAIN
# =====================================================
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143

# Contract addresses — fill in after deploying contracts/solidity/
VOICE_REGISTRY_ADDRESS=0x
VOICE_MARKETPLACE_ADDRESS=0x
PLATFORM_ADDRESS=0x

# =====================================================
# BACKEND SERVER
# =====================================================
PORT=8000
BACKEND_URL=http://localhost:8000
PYTHONUNBUFFERED=1

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
LOG_LEVEL=info
API_SECRET_KEY=change_me

# Storage paths (relative to backend/)
AUDIO_STORAGE_PATH=./storage/audio
PREVIEW_STORAGE_PATH=./storage/previews

# x402 pay-per-use — 0.01 MON in wei (10^16)
DEFAULT_PRICE_WEI=10000000000000000

# =====================================================
# LIVEKIT — optional, for live voice agent rooms
# Get credentials at https://cloud.livekit.io
# =====================================================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
