PORT=8000
PYTHONUNBUFFERED=1

# Monad Testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143

# Contract addresses — fill after deploying contracts/solidity/
VOICE_REGISTRY_ADDRESS=0x
VOICE_MARKETPLACE_ADDRESS=0x

# Storage
AUDIO_STORAGE_PATH=./storage/audio
PREVIEW_STORAGE_PATH=./storage/previews

# API
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=info

# x402 pay-per-use — 0.01 MON in wei
DEFAULT_PRICE_WEI=10000000000000000

# Sarvam TTS
SARVAM_API_KEY=your_sarvam_api_key

# LiveKit (optional)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
