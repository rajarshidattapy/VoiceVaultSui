# Backend-only environment variables
# These are NOT exposed to the browser (no VITE_ prefix)

# Server Configuration
PORT=8000
BACKEND_URL=http://localhost:8000
# In production, set this to a durable path shared by API, MCP, and worker.
# VOICEVAULT_STORAGE_DIR=/var/lib/voicevault

# Sui Configuration
SUI_ADDRESS=0x...
SUI_ALIAS=your-wallet-alias
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io
SUI_FULL_NODE_URL=https://fullnode.testnet.sui.io:443
SUI_GAS_BUDGET=10000000

# Smart Contracts
SUI_PACKAGE_ID=0x1ad12f0fd581dbd4fef7a30c9cff9bececfca1da450fe53257791502b3db073d
SUI_UPGRADE_CAPABILITY=0x...
SUI_VOICE_REGISTRY_ID=0xfad2808bcd104197b53b1fddede5f25d5c16303b147d280c2aa7ff69d27e5d59

# Walrus Storage Configuration
WALRUS_STORAGE_MODE=local
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=http://localhost:8000/api/walrus
WALRUS_EPOCHS=5
WALRUS_DELETABLE=true
WALRUS_MAX_BLOB_SIZE=10485760

# For production on OCI, use:
# WALRUS_STORAGE_MODE=remote
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Murf TTS Configuration
# Keep this key backend-only. Do not expose it as a VITE_ frontend variable.
MURF_API_KEY=your_murf_api_key_here
MURF_VOICE_ID=Ken
MURF_LOCALE=en-US
MURF_FORMAT=WAV
MURF_SAMPLE_RATE=44100

# API Security
API_SECRET_KEY=your_secret_key_here_change_in_production
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# For production, update CORS_ORIGINS to your frontend URL:
# CORS_ORIGINS=["https://voicevault.vercel.app"]

# Logging
LOG_LEVEL=info

# Set these on OCI when systemd supervises the worker as its own service.
LIVEKIT_AGENT_EXTERNAL=false
LIVEKIT_AGENT_MANAGED=true
LIVEKIT_AGENT_MODE=start

# Note: This file should be used locally only.
# In production, set environment variables through the platform or /etc/voicevault/voicevault.env.
